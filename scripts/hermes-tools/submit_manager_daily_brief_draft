#!/usr/bin/env python3
"""Submit a Hermes-authored Manager Daily Brief draft through app validation."""

from __future__ import annotations

import argparse

from pet_resort_api import BridgeError, add_payload_file_argument, fail_safe, read_json_payload, request_json, write_json


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Post a Manager Daily Brief draft packet to the deterministic app validation endpoint."
    )
    add_payload_file_argument(parser, "draft")
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    try:
        draft = read_json_payload(args.payload_file)
        payload = request_json("POST", "/agent/drafts/manager-daily-brief", body=draft)
        write_json(payload)
        return 0
    except BridgeError as exc:
        return fail_safe(exc)


if __name__ == "__main__":
    raise SystemExit(main())
