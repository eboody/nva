#!/usr/bin/env python3
"""Fetch an app-owned Manager Daily Brief context packet for Hermes."""

from __future__ import annotations

import argparse

from pet_resort_api import BridgeError, fail_safe, request_json, write_json


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Call the deterministic app context endpoint for a Manager Daily Brief packet."
    )
    parser.add_argument("--location-id", required=True, help="Pet resort location UUID.")
    parser.add_argument("--operating-day", required=True, help="Operating day as YYYY-MM-DD.")
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    try:
        payload = request_json(
            "GET",
            "/agent/context/manager-daily-brief",
            query={"location_id": args.location_id, "operating_day": args.operating_day},
        )
        write_json(payload)
        return 0
    except BridgeError as exc:
        return fail_safe(exc)


if __name__ == "__main__":
    raise SystemExit(main())
