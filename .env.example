# Copy to .env for local development. Do not put production secrets here.
PET_RESORT_API_ADDR=127.0.0.1:3001
PET_RESORT_AGENT_RUNTIME_MODE=fake
DATABASE_URL=postgres://pet_resort:pet_resort@127.0.0.1:54329/pet_resort
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=pet_resort_local
MINIO_SECRET_KEY=pet_resort_local_password
MINIO_BUCKET=pet-resort-evidence-local
LIVE_CUSTOMER_MESSAGING=disabled
LIVE_PROVIDER_WRITES=disabled
