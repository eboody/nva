# Copy to .env for local development. Do not put production secrets here.
PET_RESORT_API_ADDR=127.0.0.1:3001
PET_RESORT_AGENT_RUNTIME_MODE=fake
DATABASE_URL=postgres://pet_resort:pet_resort@127.0.0.1:54329/pet_resort
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=pet_resort_local
MINIO_SECRET_KEY=pet_resort_local_password
MINIO_BUCKET=pet-resort-evidence-local

# Optional local agent memory/context infrastructure. These are local placeholders,
# not production credentials. Keep real/shared keys in .env, 1Password, or deploy secrets.
OPENVIKING_ENDPOINT=http://127.0.0.1:1933
OPENVIKING_API_KEY=***
OPENVIKING_ACCOUNT=nva-local
OPENVIKING_USER=local-developer
OPENVIKING_AGENT=hermes-nva-local
OPENVIKING_WITH_BOT=0
OPENVIKING_PUBLIC_BASE_URL=
OPENVIKING_CONFIG_FILE=/app/.openviking/ov.conf
# Optional: set only in local .env/secret manager, never commit a real ov.conf JSON.
# OPENVIKING_CONF_CONTENT=

LIVE_CUSTOMER_MESSAGING=disabled
LIVE_PROVIDER_WRITES=disabled
